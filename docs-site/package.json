{
  "name": "@roastcodes/ttdash-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/run-astro.mjs dev",
    "check": "node scripts/run-astro.mjs check && markdownlint-cli2 \"src/content/docs/**/*.{md,mdx}\"",
    "build": "node scripts/run-astro.mjs build",
    "preview": "node scripts/run-astro.mjs preview",
    "verify": "npm run check && npm run build"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/starlight": "0.41.3",
    "astro": "7.1.3",
    "starlight-links-validator": "0.25.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "markdownlint-cli2": "0.23.1",
    "typescript": "~7.0.2"
  }
}
